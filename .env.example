# =============================================================
# BunRadio - Configuración (TODO es opcional)
# =============================================================
# Ejecuta el binario sin .env y funciona automáticamente.
# Solo edita lo que quieras cambiar.

# Puerto HTTP (auto-detectado si está ocupado)
# PORT=808

# Puerto RTMP (auto-detectado si está ocupado)
# RTMP_PORT=1935

# Clave de transmisión (se genera automáticamente si no la pones)
# RTMP_STREAM_KEY=stream

# Límite de oyentes simultáneos
# MAX_LISTENERS=500

# Búfer inicial para reproducción inmediata (64 KB)
# PREBUFFER_BYTES=65536

# CORS (orígenes permitidos)
# CORS_ORIGIN=*

# Credenciales del panel admin (sin contraseña si se deja vacío)
# ADMIN_USER=admin
# ADMIN_PASSWORD=adminsecurepassword

# Nivel de logs: debug | info | warn | error
# LOG_LEVEL=info

# Bitrate de audio MP3 (128, 192, 320)
# STREAM_BITRATE_KBPS=320

# Carpeta de música fallback (auto-detecta 'musica', 'music', 'audio', 'songs')
# FALLBACK_SOURCE=musica

# DSP: compresor/limitador de volumen estilo radio FM
# AUDIO_PROCESSING=true

# Crossfade entre canciones en segundos (0 = desactivado)
# CROSSFADE_SECONDS=2

# Tiempo mínimo de stream RTMP antes de cortar fallback (segundos)
# RTMP_MIN_LIVE_SECONDS=10

# Codificación MP3 nativa via FFI:
#   auto  → intenta nativo, fallback ffmpeg (recomendado)
#   true  → fuerza nativo
#   false → usa ffmpeg
# USE_NATIVE_LAME=auto
