# Puerto HTTP para oyentes y panel de administración
PORT=4321

# Puerto RTMP para ingesta desde OBS Studio
RTMP_PORT=1935

# Clave de transmisión RTMP (Stream Key)
RTMP_STREAM_KEY=stream

# Límite máximo de oyentes simultáneos
MAX_LISTENERS=500

# Búfer inicial para reproducción inmediata en oyentes (64 KB)
PREBUFFER_BYTES=65536

# Configuración CORS (orígenes permitidos)
CORS_ORIGIN=*

# Credenciales de acceso para el panel de administración (/admin)
# Si se dejan en blanco, el panel estará accesible sin contraseña.
ADMIN_USER=admin
ADMIN_PASSWORD=adminsecurepassword

# Nivel de logs: debug | info | warn | error
LOG_LEVEL=info

# Bitrate de audio para la transcodificación a MP3 (p. ej., 128, 192, 320)
STREAM_BITRATE_KBPS=320

# Ruta al archivo de audio local para el sistema de fallback (ej: musica/04 - I'm A Believer - Smash Mouth.flac)
FALLBACK_SOURCE=musica

# Procesamiento dinámico de sonido (compresor/limitador de volumen estilo radio FM): true | false
AUDIO_PROCESSING=true

# Tiempo de fundido (crossfade) entre canciones y emisiones en segundos (0 para desactivar)
CROSSFADE_SECONDS=2

# Codificación MP3 nativa via Bun.FFI + libmp3lame (sin proceso ffmpeg):
#   auto  → intenta nativo, fallback ffmpeg si no disponible (recomendado)
#   true  → fuerza nativo, error si libmp3lame no está
#   false → usa ffmpeg master encoder (comportamiento clásico)
USE_NATIVE_LAME=auto
